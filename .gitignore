# =============================================================================
# .gitignore -- Windows Security Audit Project
# =============================================================================
# Version:     6.1.2
# Updated:     2026-04-25
# Description: Excludes audit output artifacts, runtime logs, editor metadata,
#              OS junk files, build/package artifacts, test artifacts, and
#              sensitive data from version control. Only source scripts,
#              modules, shared components, tests, CI workflows, and
#              documentation should be tracked.
# =============================================================================


# =============================================================================
# AUDIT OUTPUT ARTIFACTS
# =============================================================================
# Generated reports, exports, and companion files produced by script execution.
# These are per-run artifacts and must never be committed.
# =============================================================================

# HTML reports and JSON companion files
*.html
*.htm

# Structured data exports (CSV, JSON, XML, Excel, TXT)
# NOTE: docs/*.md and project config JSONs are NOT matched -- these patterns
#       only catch loose export files in working directories.
SecurityAudit-*.csv
SecurityAudit-*.json
SecurityAudit-*.xml
SecurityAudit-*.xls
SecurityAudit-*.xlsx
SecurityAudit-*.txt
Windows-Audit-*.csv
Windows-Audit-*.json
Windows-Audit-*.xml
Windows-Audit-*.xls
Windows-Audit-*.xlsx
Windows-Audit-*.txt
audit-*.csv
audit-*.html
audit-*.json
audit-*.xml
audit-*.xls
audit-*.xlsx
audit-*.txt

# Catch-all for any audit output directory the script writes to
/output/
/outputs/
/results/
/reports/
/Reports/

# Baseline files generated for drift comparison
baseline-*.json
baseline.json
*.baseline.json

# Rollback scripts generated by -RollbackPath
rollback-*.ps1
rollback-*.json

# Group Policy export files generated by -ExportGPO
*.pol
gpo-export-*.zip
gpo-export-*/


# =============================================================================
# RUNTIME LOGS
# =============================================================================
# Execution logs, debug traces, and remediation audit trails generated during
# script runs. Log retention is the operator's responsibility, not the repo's.
# =============================================================================

# Log files (all formats)
*.log
*.log.*
*.log-*

# Log directory generated by auto-logging in v6.1.2
/logs/
/Logs/

# Structured/JSON logs
*.jsonlog
*.ndjson

# Remediation logs and audit trails
remediation-*.log
remediation-*.txt
remediation-*.json
audit-trail-*.log
audit-trail-*.txt


# =============================================================================
# POWERSHELL ARTIFACTS
# =============================================================================
# Module caches, analysis output, transcript files, history, and other
# PowerShell runtime byproducts.
# =============================================================================

# PSScriptAnalyzer results
*ScriptAnalyzer*.xml
*ScriptAnalyzer*.json
*ScriptAnalyzer*.csv
PSScriptAnalyzerResults.*

# PSReadLine history (must never be committed -- may contain credentials)
ConsoleHost_history.txt
*_history.txt
*_PSReadLine*.txt

# PowerShell module cache and help
/PSModulePath/
**/ModuleAnalysisCache
PowerShellGet/InstalledModules.json
PSRepositories.xml

# PowerShell transcripts (Start-Transcript output)
PowerShell_transcript*.txt
*_transcript_*.txt
transcript-*.txt

# PowerShell SDK / .NET runtime artifacts
*.exe
*.dll
*.pdb
*.lib
*.obj
*.idb
*.ilk
*.exp
*.mui

# PowerShell data files (if generated at runtime)
*.clixml
*.psd1.bak

# PowerShell Job artifacts (background jobs)
PSJobs/
*.job

# PowerShell help cache
**/HelpCache/
**/help.cache


# =============================================================================
# PESTER TEST ARTIFACTS
# =============================================================================
# Test results, coverage reports, and Pester runtime files.
# =============================================================================

# Pester test result files
test-results-*.xml
TestResults*.xml
PesterResults*.xml
NUnit*.xml

# Code coverage reports
coverage-*.xml
coverage*.json
coverage.opencover.xml
JaCoCo*.xml
**/coverage/
**/htmlcov/

# Pester debug output
*.Pester.log
PesterRun*.txt

# Test temp directory
TestDrive/
TestDrive-*/


# =============================================================================
# EDITOR AND IDE FILES
# =============================================================================
# Workspace settings, caches, and metadata from common editors.
# Personal editor configs should stay local, not in the repo.
# =============================================================================

# Visual Studio Code
.vscode/
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
*.code-workspace

# VS Code Codespaces / Dev Containers
.devcontainer/devcontainer.local.json

# Visual Studio
.vs/
*.suo
*.user
*.userosscache
*.sln.docstates
*.opendb
*.VC.db
*.VC.opendb
*.psess
*.vsp
*.vspx
*.sap

# JetBrains (IntelliJ, Rider, ReSharper, etc.)
.idea/
*.iml
*.iws
*.ipr
*.DotSettings.user

# PowerShell ISE artifacts
*.psproj
*.psprojs

# Sublime Text
*.sublime-workspace
*.sublime-project

# Vim / Neovim
*.swp
*.swo
*~
.netrwhist
tags

# Emacs
\#*\#
.\#*
*.elc

# Notepad++
*.bak
nppBackup/
backup/

# Atom
.atom/

# Eclipse / Theia
.metadata/
.project
.cproject
.settings/


# =============================================================================
# OPERATING SYSTEM FILES
# =============================================================================
# Desktop metadata, thumbnail caches, and filesystem artifacts from Windows,
# macOS, and Linux. None of these belong in a repository.
# =============================================================================

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
Desktop.ini
$RECYCLE.BIN/
*.stackdump
[Dd]esktop.ini
desktop.ini

# Windows shortcut files
*.lnk

# Windows Installer files
*.cab
*.msi
*.msix
*.msm
*.msp

# Windows hibernation / paging / dumps
hiberfil.sys
pagefile.sys
swapfile.sys
*.dmp
*.mdmp
MEMORY.DMP
Minidump/

# Windows registry exports
*.reg

# Windows event-log exports
*.evtx
*.evt

# macOS
.DS_Store
.DS_Store?
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes
Icon?
.fseventsd
.TemporaryItems
.VolumeIcon.icns
.com.apple.timemachine.donotpresent

# Linux
*~
.fuse_hidden*
.directory
.Trash-*
.nfs*


# =============================================================================
# TEMPORARY AND BACKUP FILES
# =============================================================================
# Scratch files, backups, archives, and intermediate artifacts that should
# never enter version control.
# =============================================================================

# Generic temp/backup patterns
*.tmp
*.temp
*.bak
*.bak.*
*.backup
*.old
*.orig
*.save
*.cache

# Archive files (unless intentionally tracked at known release paths)
*.zip
*.tar
*.tar.gz
*.tgz
*.7z
*.rar
*.gz
*.bz2
*.xz

# Diff and patch artifacts
*.patch
*.diff
*.rej

# Snapshot / version control noise
*.merge
*.merge_file_*
.merge_file_*


# =============================================================================
# PYTHON ARTIFACTS (Build/Verification Scripts)
# =============================================================================
# Module generation and verification scripts may produce Python bytecode,
# virtual environments, and tool caches.
# =============================================================================

# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
.env/
.venv/
env/
venv/
ENV/
env.bak/
venv.bak/

# Distribution / packaging
*.egg-info/
*.egg
dist/
build/
*.whl
*.manifest

# Pytest / coverage
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/

# Mypy / type checking
.mypy_cache/
.dmypy.json
.pyre/
.pytype/

# Ruff / Black / pyflakes
.ruff_cache/


# =============================================================================
# NODE.JS / NPM ARTIFACTS (If tooling is added)
# =============================================================================
# Included proactively in case linting, formatting, or CI tooling introduces
# Node.js dependencies in the future.
# =============================================================================

node_modules/
npm-debug.log*
yarn-error.log*
yarn-debug.log*
.yarn/cache
.yarn/unplugged
.yarn/build-state.yml
.yarn/install-state.gz
.pnp.*
package-lock.json
yarn.lock
pnpm-lock.yaml


# =============================================================================
# CI/CD AND DEVOPS
# =============================================================================
# Pipeline artifacts, test results, and deployment-specific files generated
# by CI/CD systems. Workflows themselves (in .github/workflows/) ARE tracked.
# =============================================================================

# GitHub Actions runner artifacts
.github/actions/*/dist/
_actions/
_runner/
_temp/
_work/

# Azure DevOps
TestResults/
*.trx

# Generic CI artifacts
/artifacts/
/coverage/
/test-results/
/test-output/
TestResult.xml

# act (local GitHub Actions runner)
.actrc
.act/

# Docker (if used for testing)
Dockerfile.local
docker-compose.override.yml


# =============================================================================
# SECURITY AND SENSITIVE DATA
# =============================================================================
# Credentials, keys, tokens, and environment-specific configuration that must
# never be committed. Even for a read-only audit tool, operators may create
# local config files with sensitive paths or identifiers.
# =============================================================================

# Environment and secrets files
.env
.env.*
!.env.example
*.pem
*.key
*.pfx
*.cer
*.crt
*.p12
*.p7b
*.p7c
*.csr
*.der

# SSH keys
id_rsa
id_rsa.pub
id_dsa
id_dsa.pub
id_ed25519
id_ed25519.pub
id_ecdsa
id_ecdsa.pub
known_hosts
known_hosts.old

# GPG / age encrypted files
*.gpg
*.age
*.asc
secring.*
pubring.*

# Credential files
*credentials*
*secrets*
*token*
*.token
!**/docs/**
!**/wiki/**
!**/README*
!**/*.example.*

# Local configuration overrides
local.settings.json
appsettings.local.json
appsettings.development.json
config.local.*
*.local.json
*.local.config

# Cloud provider credentials
.aws/
.azure/
.gcloud/
.kube/config
*.kubeconfig
azureProfile.json

# HashiCorp Vault / 1Password / LastPass
.vault_pass
.vault-token
vault-audit.log
*.opvault


# =============================================================================
# WINDOWS-SPECIFIC SECURITY ARTIFACTS
# =============================================================================
# Files an audit tool might inadvertently create or that contain sensitive
# system state.
# =============================================================================

# Windows Defender exclusion lists / state exports
defender-state-*.xml
defender-config-*.json

# BitLocker recovery keys (must NEVER be committed)
*BitLocker-Recovery*
*recovery-key*
RecoveryKeys/

# Windows certificate store exports
*.sst

# Windows credential manager exports
credentials-export-*.xml
credman-*.xml

# AD/LDAP exports
*.ldif
*.ldap
ad-export-*.csv

# SCCM / Intune exports
mecm-export-*.xml
intune-export-*.json

# Audit policy backup/export
auditpol-backup-*.csv
secedit-backup-*.inf


# =============================================================================
# PROJECT-SPECIFIC EXCLUSIONS
# =============================================================================
# Patterns specific to the Windows Security Audit project structure,
# development workflow, and known generated artifacts.
# =============================================================================

# Task management files (local development tracking)
# Note: specific files in tasks/ ARE tracked via explicit inclusions below
/tasks/*
!/tasks/sync_function.md
!/tasks/deferred-work.md
!/tasks/lessons.md
!/tasks/todo.md

# Brace-expansion artifacts and generation intermediates
*{*,*}*

# Module generation scripts output (intermediate .ps1 before verification)
/gen_output/
/generated/

# Verification scan results
/scan_results/
verify_*.txt
unused_vars_*.txt
psanalysis_*.txt
brace_balance_*.txt

# Performance profiling output
profile_*.txt
profile_*.json
timing_*.log
*.bench
*.benchmark

# Remediation file-based input (operator-specific)
remediation_input_*.json

# Local audit configurations
audit-config.local.json
modules-include.local.txt
modules-exclude.local.txt


# =============================================================================
# EXPLICIT INCLUSIONS (Override patterns above where needed)
# =============================================================================
# Force-track files that might otherwise match an exclusion pattern.
# =============================================================================

# Track documentation markdown
!docs/**/*.md
!README.md
!CHANGELOG.md
!CONTRIBUTING.md
!LICENSE.md
!SECURITY.md
!USAGE_GUIDE.md
!RELEASE-NOTES*.md

# Track GitHub community files
!.github/**
!.github/**/*.md
!.github/**/*.yml
!.github/**/*.yaml
!.github/ISSUE_TEMPLATE/**
!.github/PULL_REQUEST_TEMPLATE.md
!.github/CODE_OF_CONDUCT.md
!.github/FUNDING.yml

# Track the shared library
!shared_components/**/*.ps1

# Track all module source files
!modules/**/*.ps1

# Track the main script
!Windows-Security-Audit.ps1

# Track test files
!tests/**/*.ps1
!tests/**/*.psd1
!tests/**/*.psm1
!tests/**/README.md

# Track wiki sidebar/footer special files
!docs/wiki/_Sidebar.md
!docs/wiki/_Footer.md

# Always track .gitignore and .gitattributes
!.gitignore
!.gitattributes
